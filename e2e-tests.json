      "name": "1. Регистрация пользователя",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", () => { pm.response.to.have.status(201); });",
              "const jsonData = pm.response.json();",
              "pm.expect(jsonData.user.id).to.not.be.undefined;",
              "pm.expect(jsonData.token).to.not.be.undefined;",
              "pm.environment.set('userId', jsonData.user.id);",
              "pm.environment.set('token', jsonData.token);",
              "console.log('User created with id: ' + jsonData.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Тестовый Пользователь\",\n  \"email\": \"test@example.com\",\n  \"password\": \"securePass123\",\n  \"phone\": \"+79991234567\",\n  \"deliveryAddress\": \"г. Москва, ул. Ленина, д.1\"\n}"
        },
        "url": {
          "raw": "{{userUrl}}/api/v1/auth/register",
          "host": ["{{userUrl}}"],
          "path": ["api", "v1", "auth", "register"]
        }
