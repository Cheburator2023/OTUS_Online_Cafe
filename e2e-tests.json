    {
      "name": "8.5. Установка корзины для сценария B (замена на 1 блюдо каждого типа)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.expect(jsonData.items.length).to.eql(2);",
              "const item1 = jsonData.items.find(i => i.productId === 1);",
              "pm.expect(item1.quantity).to.eql(1);",
              "const item2 = jsonData.items.find(i => i.productId === 2);",
              "pm.expect(item2.quantity).to.eql(1);",
              "console.log('Cart successfully set to 1 item of each product');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 1 },\n    { \"productId\": 2, \"quantity\": 1 }\n  ]\n}"
        },
        "url": {
          "raw": "{{orderUrl}}/api/v1/carts/{{userId}}/items",
          "host": ["{{orderUrl}}"],
          "path": ["api", "v1", "carts", "{{userId}}", "items"]
        }
      }
    },
    {
      "name": "9. Сценарий B: клиент согласен ждать (acceptWaiting=true) → создаётся PENDING заказ",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Сбрасываем orderId перед новым заказом",
              "pm.environment.unset('orderId');",
              "",
              "// Получаем ближайший доступный слот доставки",
              "const deliveryUrl = pm.environment.get(\"deliveryUrl\") || \"http://delivery.arch.homework\";",
              "const afterTimeDate = new Date(Date.now() + 2 * 60 * 60 * 1000);",
              "const year = afterTimeDate.getUTCFullYear();",
              "const month = String(afterTimeDate.getUTCMonth() + 1).padStart(2, '0');",
              "const day = String(afterTimeDate.getUTCDate()).padStart(2, '0');",
              "const hours = String(afterTimeDate.getUTCHours()).padStart(2, '0');",
              "const minutes = String(afterTimeDate.getUTCMinutes()).padStart(2, '0');",
              "const seconds = String(afterTimeDate.getUTCSeconds()).padStart(2, '0');",
              "const afterTime = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;",
              "const url = `${deliveryUrl}/api/v1/delivery/slots/nearest?afterTime=${encodeURIComponent(afterTime)}&limit=1`;",
              "pm.sendRequest({",
              "    url: url,",
              "    method: 'GET',",
              "    header: { 'Authorization': 'Bearer ' + pm.environment.get('token') }",
              "}, function (err, response) {",
              "    if (err) {",
              "        console.error(err);",
              "        pm.environment.set('deliverySlotTime', '');",
              "        return;",
              "    }",
              "    if (response.code !== 200) {",
              "        console.warn('Delivery slots endpoint returned ' + response.code);",
              "        pm.environment.set('deliverySlotTime', '');",
              "        return;",
              "    }",
              "    const slots = response.json();",
              "    if (!slots || slots.length === 0) {",
              "        console.warn('No available delivery slots found');",
              "        pm.environment.set('deliverySlotTime', '');",
              "    } else {",
              "        let slotTime = slots[0].timeSlot;",
              "        if (slotTime && slotTime.includes('T')) {",
              "            slotTime = slotTime.replace('T', ' ');",
              "        }",
              "        pm.environment.set('deliverySlotTime', slotTime);",
              "        console.log('Selected delivery slot: ' + slotTime);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.expect(jsonData.status).to.eql('PENDING');",
              "pm.expect(jsonData.amount).to.eql(51.00);",
              "pm.expect(jsonData.preparationTimeMinutes).to.be.at.least(10);",
              "pm.environment.set('orderId', jsonData.id);",
              "console.log('Pending order created with id: ' + jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
